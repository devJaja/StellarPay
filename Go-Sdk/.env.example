# ─────────────────────────────────────────────────────────────────
# StellarPay — Go Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Server port
PORT=8080

# Comma-separated list of allowed CORS origins
# Example: http://localhost:5173,https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Stellar Source Account Secret Key
# Used to sign and submit transactions to the Stellar network.
# Generate a testnet keypair at: https://laboratory.stellar.org/#account-creator
# In CI/CD: set as STELLAR_SOURCE_SECRET in GitHub repository secrets.
STELLAR_SOURCE_SECRET=S...YOUR_STELLAR_SECRET_KEY_HERE

# API Key for backend authentication
# Clients must send this as the X-API-Key header.
# In CI/CD: set as API_KEY in GitHub repository secrets.
API_KEY=your_secure_api_key_here
