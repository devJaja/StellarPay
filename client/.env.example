# ─────────────────────────────────────────────────────────────────
# StellarPay — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Supabase Configuration
# Get these from your Supabase project settings → API section
# https://app.supabase.com/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Go Backend Authentication
# Must match API_KEY set in Go-Sdk/.env (sent as X-API-Key header)
VITE_API_KEY=your_actual_api_key_here

# Go Backend Base URL
# Local development: http://localhost:8080
# Production:        https://your-deployed-backend-url
VITE_API_BASE_URL=http://localhost:8080

# Deployed Soroban Contract Addresses (Stellar Testnet)
# Obtain these after deploying the contracts in early-wager-contract/
VITE_CONTRACT_TOKEN=<deployed-token-contract-address>
VITE_CONTRACT_WAGE=<deployed-early-wage-contract-address>
